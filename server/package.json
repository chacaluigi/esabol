{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "node src/main.js",
    "dev": "node --env-file .env --watch src/main.js",
    "migrate": "node --env-file .env ./node_modules/.bin/sequelize db:migrate",
    "migrate:undo": "node --env-file .env ./node_modules/.bin/sequelize db:migrate:undo",
    "migrate:status": "node --env-file .env ./node_modules/.bin/sequelize db:migrate:status",
    "migration:generate": "npx sequelize-cli migration:generate --name"
  },
  "keywords": [],
  "author": "",
